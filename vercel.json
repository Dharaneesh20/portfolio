{
  "buildCommand": "npm run build && cp -r ../public/* client/dist/",
  "outputDirectory": "client/dist",
  "installCommand": "npm install --prefix client",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
